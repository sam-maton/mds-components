{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "mds-components": {
      "projectType": "library",
      "root": "projects/mds-components",
      "sourceRoot": "projects/mds-components/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/mds-components/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/mds-components/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/mds-components/tsconfig.spec.json"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "mds-components:build",
            "tsConfig": "tsconfig.storybook.json",
            "styles": ["node_modules/@smaton/mds-styles/src/index.css"],
            "compodoc": false,
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "mds-components:build",
            "tsConfig": "tsconfig.storybook.json",
            "styles": ["node_modules/@smaton/mds-styles/src/index.css"],
            "compodoc": false,
            "outputDir": "dist/storybook"
          }
        }
      }
    }
  }
}
